# ----------------------- OpenRouter -----------------------
OPENROUTER_API_KEY=sk-or-...

# Model: e.g. qwen/qwen3.5-9b, qwen/qwen3-vl-8b-instruct, qwen/qwen3.5-flash-02-23
MODEL=qwen/qwen3.5-9b

# Examples: deepinfra/bf16  |  together  |  fireworks
PROVIDERS=deepinfra/bf16,together

# Default max output tokens for model responses
MAX_OUTPUT_TOKENS=4096
# ----------------------- End OpenRouter -----------------------


# ------------------------ Xiaomi MiMo (fetch-based, takes priority over OpenAI Compat) -----------------------
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
XIAOMI_MODEL=mimo-v2.5
# ------------------------ End Xiaomi MiMo -----------------------

# ------------------------ OpenAI Compat -----------------------
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=
# ------------------------ End OpenAI Compat -----------------------

# ----------------------- Telegram Bot -----------------------
TELEGRAM_BOT_TOKEN=
# ----------------------- End Telegram Bot -----------------------


# ----------------------- Server -----------------------
# API server (set to non-zero to enable)
API_PORT=3000

# Allowed CORS origins (comma-separated). Leave empty to disable CORS.
CORS_ORIGINS=https://app.example.com,http://localhost:5173

# Directory for SQLite DB and crons.json (relative to project root)
DATA_DIR=./data
# ----------------------- End Server -----------------------

# ----------------------- Google Drive -----------------------
# Google OAuth (user) credentials (optional alternative to service account)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Optional Drive folder to upload into
DRIVE_FOLDER_ID=

# Set to 0 to keep files private
DRIVE_PUBLIC=1
# ----------------------- End Google Drive -----------------------