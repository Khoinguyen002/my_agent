OPENROUTER_API_KEY=sk-or-...

# Main model for agent
MODEL=qwen/qwen3.5-9b


# Optional provider routing: "<provider>[/<quantization>]"
PROVIDER=deepinfra/bf16

# Default max output tokens for model responses
MAX_OUTPUT_TOKENS=4096

TELEGRAM_BOT_TOKEN=

# Directory for SQLite DB and crons.json (relative to project root)
DATA_DIR=./data

# API server (set to non-zero to enable)
API_PORT=3000


# Product hints (comma-separated)
PRODUCT_HINTS=ca rot,su tim,la lot

# Google OAuth (user) credentials (optional alternative to service account)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Optional Drive folder to upload into
DRIVE_FOLDER_ID=

# Set to 0 to keep files private
DRIVE_PUBLIC=1
