OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Router model: fast/cheap — used for tool selection only
ROUTER_MODEL=qwen/qwen3.5-9b

# Executor model: quality — used for final streaming response
EXECUTOR_MODEL=qwen/qwen3.5-9b

# Optional provider routing: "<provider>[/<quantization>]"
# Examples: deepinfra/bf16  |  together/fp8  |  fireworks
ROUTER_PROVIDER=deepinfra/bf16
EXECUTOR_PROVIDER=deepinfra/bf16

TELEGRAM_BOT_TOKEN=

# Directory for SQLite DB and crons.json (relative to project root)
DATA_DIR=./data
